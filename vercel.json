{
  "version": 2,
  "rewrites": [{ "source": "/", "destination": "/The_Great_Redeployment.html" }],
  "headers": [
    {
      "source": "/The_Great_Redeployment.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
